generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Job {
  id          String   @id @default(cuid())
  threadId    String
  jobPost     String   @db.Text
  jobMetadata Json
  status      String   @default("created")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([threadId])
}

model BuyerThreadState {
  id                 String   @id @default(cuid())
  threadId           String   @unique
  status             String
  messages           Json
  questionCount      Int
  domainQuestionCount Int
  domainPhaseComplete Boolean
  profileAnswers     Json
  jobPost            String?  @db.Text
  placeholders       Json
  sellerDecisions    Json
  matchedSellers     Json?
  matchingStatus     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model SellerProfile {
  id             String   @id @default(cuid())
  threadId       String
  sellerProfile  String   @db.Text
  profileMetadata Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([threadId])
}

model SellerThreadState {
  id                  String   @id @default(cuid())
  threadId            String   @unique
  status              String
  messages            Json
  questionCount       Int
  domainQuestionCount Int
  domainPhaseComplete Boolean
  profileAnswers      Json
  sellerProfile       String?  @db.Text
  placeholders        Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
